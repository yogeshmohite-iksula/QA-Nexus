# pnpm workspace config
# Hoist better-auth to workspace-root node_modules so TypeScript (tsc
# --noEmit, moduleResolution: bundler in apps/web/tsconfig.json) can
# resolve the package's subpath exports (better-auth/react,
# better-auth/client/plugins) via standard node_modules walk-up.
#
# Without this, pnpm 10 deduplicates better-auth into
# node_modules/.pnpm/node_modules/ (shared peer area) which Next.js/
# SWC can resolve at build time but tsc cannot (it only walks standard
# node_modules paths, not .pnpm internals).
#
# Minimal surface: only better-auth is hoisted; all other packages
# remain in pnpm's strict isolation model.
public-hoist-pattern[]=better-auth
