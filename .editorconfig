# QA Nexus PM1 — root .editorconfig
# Generated 2026-04-26
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
# Trailing whitespace in markdown is meaningful (line break)
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2
