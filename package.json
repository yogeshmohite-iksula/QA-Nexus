{
  "name": "qa-nexus",
  "version": "0.0.0",
  "private": true,
  "description": "QA Nexus PM1 — AI-native QA management platform for Iksula Services (monorepo root)",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/yogeshmohite-iksula/QA-Nexus.git"
  },
  "engines": {
    "node": "20.x",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint && prettier --check .",
    "lint:fix": "pnpm -r run lint:fix && prettier --write .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm --filter web run test:e2e",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
