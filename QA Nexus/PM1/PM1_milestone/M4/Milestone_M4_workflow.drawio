<mxCell id="legend_text" value="Phase 1: Tester executes steps, captures evidence (screenshots, logs, HAR)&#xa;Phase 2: On failure, create defect with auto-assignment by component (A4)&#xa;Phase 3: Async A4 RCA job analyzes evidence → 5 layers of root cause → confidence scoring&#xa;Phase 4: Create Jira issue → register webhook → bidirectional sync (status, assignee, comments)&#xa;Dashboard: Real-time metrics updated on defect creation + execution completion&#xa;Rollback: Disable flags → manual defect creation, one-way Jira sync, no RCA" style="text;html=1;whiteSpace=wrap;fontSize=8;align=left;verticalAlign=top;spacingTop=5;spacingLeft=10;spacing=2;" vertex="1" parent="1">
<mxGeometry x="595" y="445" width="545" height="130" as="geometry" />
</mxCell>

