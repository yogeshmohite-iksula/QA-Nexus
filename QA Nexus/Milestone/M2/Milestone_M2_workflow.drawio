        <mxCell id="doc7" value="Retrieve History" style="rounded=1;whiteSpace:wrap;html=1;fillColor=#9ccc65;fontColor=white;fontSize=10;" vertex="1" parent="lane_doc">
          <mxGeometry x="10" y="400" width="260" height="40" as="geometry" />
        </mxCell>

        <!-- LANE 3: A1 Agent + RAG -->
        <mxCell id="lane_a1" value="A1 Agent + RAG (FastAPI)" style="swimlane;fontStyle=1;fontSize=12;startSize=30;fillColor=#f3e5f5;strokeColor=#ab47bc;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="620" y="60" width="280" height="700" as="geometry" />
