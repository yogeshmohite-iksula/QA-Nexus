        </mxCell>
        <mxCell id="doc6" value="Trigger PDF Export" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9ccc65;fontColor=white;fontSize=10;" vertex="1" parent="lane_doc">
          <mxGeometry x="10" y="340" width="260" height="40" as="geometry" />
