        </mxCell>
        <mxCell id="a13" value="For each section:" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ab47bc;fontColor=white;fontSize=10;" vertex="1" parent="lane_a1">
          <mxGeometry x="10" y="160" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="a14" value="Call Gemma 4 (Ollama)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ab47bc;fontColor=white;fontSize=10;" vertex="1" parent="lane_a1">
