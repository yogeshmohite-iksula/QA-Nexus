        <mxCell id="a16" value="Store Section + Score" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ab47bc;fontColor=white;fontSize=10;" vertex="1" parent="lane_a1">
          <mxGeometry x="10" y="340" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="a17" value="Log to Langfuse" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ab47bc;fontColor=white;fontSize=10;" vertex="1" parent="lane_a1">
          <mxGeometry x="10" y="400" width="260" height="40" as="geometry" />
        </mxCell>

