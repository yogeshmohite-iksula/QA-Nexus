<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-04-21" version="1.0">
  <diagram id="m2_workflow" name="M2-Workflow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" background="#ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="M2 Workflow: Knowledge Base + Document Generation" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="1000" height="30" as="geometry" />
        </mxCell>

        <!-- LANE 1: UI Layer -->
        <mxCell id="lane_ui" value="UI (TipTap)" style="swimlane;fontStyle=1;fontSize=12;startSize=30;fillColor=#e3f2fd;strokeColor=#1e3a8a;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="20" y="60" width="280" height="700" as="geometry" />
        </mxCell>
        <mxCell id="ui1" value="Click Generate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0ea5e9;fontColor=white;fontSize=10;" vertex="1" parent="lane_ui">
          <mxGeometry x="10" y="40" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ui2" value="See Progress" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0ea5e9;fontColor=white;fontSize=10;" vertex="1" parent="lane_ui">
          <mxGeometry x="10" y="100" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ui3" value="View Sections + Confidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0ea5e9;fontColor=white;fontSize=10;" vertex="1" parent="lane_ui">
          <mxGeometry x="10" y="160" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ui4" value="Edit + Comment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0ea5e9;fontColor=white;fontSize=10;" vertex="1" parent="lane_ui">
          <mxGeometry x="10" y="220" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ui5" value="Submit Approval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0ea5e9;fontColor=white;fontSize=10;" vertex="1" parent="lane_ui">
          <mxGeometry x="10" y="280" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ui6" value="Export PDF" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0ea5e9;fontColor=white;fontSize=10;" vertex="1" parent="lane_ui">
          <mxGeometry x="10" y="340" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ui7" value="View Versions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0ea5e9;fontColor=white;fontSize=10;" vertex="1" parent="lane_ui">
          <mxGeometry x="10" y="400" width="260" height="40" as="geometry" />
        </mxCell>

        <!-- LANE 2: Document Service -->
        <mxCell id="lane_doc" value="Document Service (NestJS)" style="swimlane;fontStyle=1;fontSize=12;startSize=30;fillColor=#f0f4c3;strokeColor=#9ccc65;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="320" y="60" width="280" height="700" as="geometry" />
        </mxCell>
        <mxCell id="doc1" value="Create Document" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9ccc65;fontColor=white;fontSize=10;" vertex="1" parent="lane_doc">
          <mxGeometry x="10" y="40" width="260" height="40" as="geometry" />
