        <mxCell id="e8" edge="1" parent="1" source="ui4" target="doc4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#0ea5e9;strokeWidth=2;" />
