        <mxCell id="doc2" value="Submit Hatchet Job" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9ccc65;fontColor=white;fontSize=10;" vertex="1" parent="lane_doc">
          <mxGeometry x="10" y="100" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="doc3" value="Poll Job Status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9ccc65;fontColor=white;fontSize=10;" vertex="1" parent="lane_doc">
          <mxGeometry x="10" y="160" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="doc4" value="Store Sections" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9ccc65;fontColor=white;fontSize=10;" vertex="1" parent="lane_doc">
          <mxGeometry x="10" y="220" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="doc5" value="Approval Workflow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9ccc65;fontColor=white;fontSize=10;" vertex="1" parent="lane_doc">
