        </mxCell>
        <mxCell id="db4" value="Sections + Confidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ef5350;fontColor=white;fontSize=10;" vertex="1" parent="lane_db">
          <mxGeometry x="10" y="190" width="260" height="35" as="geometry" />
        </mxCell>
        <mxCell id="db5" value="Comments + Metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ef5350;fontColor=white;fontSize=10;" vertex="1" parent="lane_db">
          <mxGeometry x="10" y="240" width="260" height="35" as="geometry" />
        </mxCell>
        <mxCell id="db6" value="Versions (immutable)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ef5350;fontColor=white;fontSize=10;" vertex="1" parent="lane_db">
          <mxGeometry x="10" y="290" width="260" height="35" as="geometry" />
        </mxCell>
        <mxCell id="db7" value="PDF (R2 Storage)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ef5350;fontColor=white;fontSize=10;" vertex="1" parent="lane_db">
