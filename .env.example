# QA Nexus PM1 — environment variables (MS0-T008)
#
# Copy this file to `.env` (gitignored) and fill in real values.
# .env.example is committed to the repo to document required keys
# without leaking secrets.
#
# Production values land in Render env vars (apps/api), not in any
# committed file. CI keys land in GitHub Secrets.
#
# Categories below match the variable groups in PM1_PRD §12 and
# Milestone_M0_Setup_v8.md MS0-T008.

# ─────────────────────────────────────────────────────────────
# Database — Postgres 15 + pgvector on Neon free 0.5 GB
# Provisioned in MS0-T012.
# Get from: Neon dashboard -> qa-nexus-db -> Connection Details
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/qa_nexus_dev?sslmode=require

# DIRECT_URL — required for `prisma migrate dev` against Neon, because the
# pooled DATABASE_URL above goes through pgBouncer which doesn't support
# Prisma's prepared statements during migration. Use the *direct* (non-pooled)
# Neon connection string here. Runtime queries still use DATABASE_URL.
# Get from: Neon dashboard -> qa-nexus-db -> Connection Details -> "Direct connection"
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/qa_nexus_dev?sslmode=require

# ─────────────────────────────────────────────────────────────
# LLM — Groq (primary) + Gemini (fallback)
# Provisioned in MS0-T017.
# Groq:    https://console.groq.com/keys
# Gemini:  https://aistudio.google.com/apikey
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Email — Resend free
# Provisioned in MS0-T014.
# Get from: https://resend.com/api-keys
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@qa-nexus.iksula.com

# ─────────────────────────────────────────────────────────────
# Storage — Cloudflare R2 free
# Provisioned in MS0-T013.
# Get from: CF dashboard -> R2 -> Manage R2 API Tokens
# Use S3-compatible endpoint for Prisma / NestJS R2 client.
# ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=1ec3036cd3c742f44d00f013b344d221
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=qa-nexus-uploads
R2_ENDPOINT=https://1ec3036cd3c742f44d00f013b344d221.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://uploads.qa-nexus.iksula.com  # custom domain optional, *.r2.dev fallback

# ─────────────────────────────────────────────────────────────
# Auth — BetterAuth (Postgres adapter, magic-link via Resend)
# Provisioned in MS0-T021. Generate secrets with:
#   openssl rand -base64 32
# ─────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=
BETTER_AUTH_URL=https://qa-nexus-api.onrender.com  # API origin
NEXT_PUBLIC_AUTH_URL=https://qa-nexus-api.onrender.com  # exposed to FE

# ─────────────────────────────────────────────────────────────
# Jira OAuth 2.0 3LO — Iksula Atlassian instance (M4 / MS0-T030)
# Provisioned in M4.
# App created at: https://developer.atlassian.com/console/myapps/
# Callback URL: https://qa-nexus-api.onrender.com/v1/jira/oauth/callback
# ─────────────────────────────────────────────────────────────
JIRA_OAUTH_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
JIRA_OAUTH_CLIENT_SECRET=ATOAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JIRA_OAUTH_REDIRECT_URI=https://qa-nexus-api.onrender.com/v1/jira/oauth/callback
JIRA_INSTANCE_URL=https://iksula.atlassian.net

# ─────────────────────────────────────────────────────────────
# Observability — OpenTelemetry → Grafana Cloud free + Better Stack
# Provisioned in MS0-T019.
# Grafana:     https://grafana.com/orgs/<org>/api-keys (Metrics Publisher)
# Better Stack: https://logs.betterstack.com -> Sources -> generate token
# ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-central-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20<base64(grafana_user:grafana_token)>
OTEL_SERVICE_NAME=qa-nexus-api
BETTER_STACK_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# App config
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001  # apps/api default; apps/web dev server uses 3000
LOG_LEVEL=info  # debug | info | warn | error

# ─────────────────────────────────────────────────────────────
# Frontend (apps/web) — exposed to client, MUST be NEXT_PUBLIC_*
# Set as build-time env vars in Cloudflare Pages dashboard for prod.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://qa-nexus-api.onrender.com  # FE -> API origin
NEXT_PUBLIC_APP_URL=https://qa-nexus-web.pages.dev  # for absolute URL composition

# ─────────────────────────────────────────────────────────────
# Cloudflare API token — for `pnpm deploy:web` from local
# Set in ~/.zprofile (Yogesh's machine), NOT in .env.
# Reference here for documentation only.
# ─────────────────────────────────────────────────────────────
# CLOUDFLARE_API_TOKEN=<set in ~/.zprofile, sourced before pnpm deploy:web>
