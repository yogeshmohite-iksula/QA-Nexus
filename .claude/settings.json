{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pre-tool-use/inject-memory.sh" }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pre-tool-use/block-dangerous.sh" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/pre-tool-use/check-secrets.sh" },
          { "type": "command", "command": ".claude/hooks/pre-tool-use/enforce-design-tokens.sh" },
          { "type": "command", "command": ".claude/hooks/pre-tool-use/enforce-pm1-stack.sh" },
          { "type": "command", "command": ".claude/hooks/pre-tool-use/enforce-rwd.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": ".claude/hooks/post-tool-use/audit-log.sh" }]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/post-tool-use/report-token-savings.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/prompt-submit/load-binding-context.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/stop/update-docs-check.sh" },
          { "type": "command", "command": ".claude/hooks/stop/cumulative-savings-report.sh" }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Edit(.claude/memory/**)",
      "Write(.claude/memory/**)",
      "Edit(.claude/hooks/**)",
      "Write(.claude/hooks/**)",
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.json)",
      "Edit(.claude/settings.local.json)",
      "Write(.claude/settings.local.json)",
      "Edit(.claude/agents/**)",
      "Write(.claude/agents/**)",
      "Edit(.claude/commands/**)",
      "Write(.claude/commands/**)",
      "Edit(.claude/rules/**)",
      "Write(.claude/rules/**)",
      "Edit(.claude/locked-deps.json)",
      "Edit(CLAUDE.md)",
      "Edit(apps/**)",
      "Write(apps/**)",
      "Bash(mkdir -p .claude/**)",
      "Bash(chmod +x .claude/hooks/**)",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(jq:*)",
      "Bash(diff:*)",

      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git stash:*)",
      "Bash(git worktree:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git merge:*)",

      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh repo view:*)",
      "Bash(gh secret list:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh run:*)",
      "Bash(gh auth:*)",

      "Bash(pnpm install:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm -r:*)",
      "Bash(pnpm --filter:*)",
      "Bash(pnpm dlx:*)",
      "Bash(pnpm --version)",

      "Bash(node --version)",
      "Bash(npx --yes @nestjs/cli@10:*)",
      "Bash(ruby -ryaml:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git checkout --:*)",
      "Bash(git restore --:*)",
      "Bash(gh repo delete:*)",
      "Bash(DROP TABLE:*)",
      "Bash(TRUNCATE:*)",
      "Edit(QA Nexus/PM1/PM1_UI_v2/**)",
      "Write(QA Nexus/PM1/PM1_UI_v2/**)",
      "Edit(.env)",
      "Write(.env)",
      "Edit(apps/**/.env)",
      "Write(apps/**/.env)"
    ]
  }
}
