{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use/inject-memory.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use/enforce-no-playwright-mcp.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use/block-dangerous.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use/check-secrets.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use/enforce-design-tokens.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use/enforce-pm1-stack.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use/enforce-rwd.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-tool-use/audit-log.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-tool-use/report-token-savings.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/post-tool-use/nudge-context-mode.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/prompt-submit/load-binding-context.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop/update-docs-check.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/stop/cumulative-savings-report.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/stop/log-token-savings.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/stop/log-session-summary.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start/sync-hooks.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/scripts/statusline.sh"
  },
