#!/bin/bash
# Husky pre-push hook for QA Nexus PM1.
#
# Four gates run in sequence:
# 1) pnpm typecheck (existing) — catches TS errors before the push lands.
# 2) prettier --check (added Day-13 (aq) — see docs/followups.md) — catches
#    formatting drift BEFORE CI lint fails. Prettier-cascade had bitten 5
#    PRs across 2 days (Day-12 #62/#75/#77/#78 → MAIN's #79 fix; Day-13
#    #85/#87 → BE+1's prettier-write fixes). Cheaper to catch at author-
#    time than chase relay-loop fixes after CI fails. Auto-fix:
#    `pnpm exec prettier --write .` then re-stage + retry push.
# 3) frozen-lockfile check (added Day 5 #4 post-mortem) — catches
#    package.json edits where pnpm-lock.yaml wasn't regenerated, which
#    breaks Render's `pnpm install --frozen-lockfile` build step. Day-5
#    #4 (e23d0d2) shipped @opentelemetry/api^1.9.1 in apps/api/
#    package.json without the lockfile bump → Render boot failed with
#    ERR_PNPM_OUTDATED_LOCKFILE for ~10 minutes until the followup fix.
# 4) CHANGELOG guard (added Day 2, Block 4(e)) — blocks pushes where any
#    commit-being-pushed touches apps/** or packages/** WITHOUT a matching
#    docs/CHANGELOG.md edit somewhere in the push range.
#
# The CHANGELOG guard is permissive: it only requires CHANGELOG.md to be
# touched ONCE in the push range — not in every commit. This lets you
# build a feature across N commits and document it in commit N+1.
#
# Bypass (only for true emergencies; document the bypass in the EOD):
#   git push --no-verify
# But the dangerous-flags hook may also need disabling, so the friction
# is intentional.

set -e

echo "→ pre-push gate 1/4: typecheck"
pnpm typecheck

echo "→ pre-push gate 2/4: prettier --check"
# Run prettier in check-only mode against the whole repo. The repo's
# .prettierrc + .prettierignore are honored. Fast — typically <2s on
# warm cache. If it fails, the script below prints a one-line auto-fix
# command + lists the offending files (capped at 10 to avoid wall of
# text). The cascade we saw on Day-12/13 was ALWAYS spec files, so the
# fixer is usually `prettier --write apps/api/src/**/__tests__/`.
if ! pnpm exec prettier --check . >/tmp/qa-nexus-prettier.log 2>&1; then
  echo ""
  echo "✗ pre-push prettier gate FAILED"
  echo ""
  echo "  Files needing format:"
  # prettier outputs one path per line prefixed with "[warn] " for
  # malformed files + "[error] " for parse failures. Both indicate
  # the push should fail. Strip the prefix so the path is copy-pasteable.
  grep -E '^\[(warn|error)\]' /tmp/qa-nexus-prettier.log \
    | head -10 \
    | sed 's/^\[warn\] /    · /' \
    | sed 's/^\[error\] /    · /'
  echo ""
  echo "  Fix:    pnpm exec prettier --write ."
  echo "  Re-stage: git add -A && git commit --amend --no-edit"
  echo "  Retry push: git push --force-with-lease"
  echo ""
  echo "  Bypass (DO NOT do this — CI lint will fail anyway):"
  echo "    git push --no-verify"
  echo ""
  exit 1
fi
echo "  ✓ all files match prettier config"

echo "→ pre-push gate 3/4: frozen-lockfile (lockfile vs package.json drift)"
# `pnpm install --frozen-lockfile --lockfile-only` reads ALL workspace
# package.json files + verifies the lockfile satisfies them, but does
# NOT actually install anything. Returns non-zero with
# ERR_PNPM_OUTDATED_LOCKFILE if drift detected. Fast — typically <2s on
# warm cache because no node_modules I/O happens.
if ! pnpm install --frozen-lockfile --lockfile-only >/dev/null 2>&1; then
  echo ""
  echo "✗ pre-push frozen-lockfile gate FAILED"
  echo ""
  echo "  pnpm-lock.yaml is out of sync with package.json. Render's"
  echo "  build step uses --frozen-lockfile and will refuse to install."
  echo ""
  echo "  Fix: run \`pnpm install\` (no flags), commit pnpm-lock.yaml,"
  echo "  retry the push."
  echo ""
  echo "  Bypass (DO NOT do this — Render WILL fail to deploy):"
  echo "    git push --no-verify"
  echo ""
  exit 1
fi
echo "  ✓ pnpm-lock.yaml matches package.json"

echo "→ pre-push gate 4/4: CHANGELOG guard"

# stdin contract for git push hooks: lines like "<local-ref> <local-sha> <remote-ref> <remote-sha>"
# We read all lines and compute the union of commits being pushed.
remote="$1"
url="$2"
zero=$(git hash-object --stdin </dev/null | tr '0-9a-f' '0')

push_commits=""
while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip deletes
  if [ "$local_sha" = "$zero" ]; then continue; fi

  if [ "$remote_sha" = "$zero" ]; then
    # New branch — compare against the default base (main on origin)
    base=$(git rev-parse origin/main 2>/dev/null || git rev-parse HEAD~20 2>/dev/null || echo "")
    if [ -n "$base" ]; then
      range="$base..$local_sha"
    else
      range="$local_sha"
    fi
  else
    range="$remote_sha..$local_sha"
  fi

  range_commits=$(git rev-list "$range" 2>/dev/null || true)
  push_commits="$push_commits $range_commits"
done

# If there's nothing to push (or stdin was empty for some reason), let it through.
if [ -z "$(echo $push_commits | xargs)" ]; then
  echo "  (no commits to push — skipping CHANGELOG guard)"
  exit 0
fi

# Get the union of all files changed across the push range.
all_changed_files=""
for sha in $push_commits; do
  files=$(git diff-tree --no-commit-id --name-only -r "$sha" 2>/dev/null || true)
  all_changed_files="$all_changed_files
$files"
done

# Filter to source paths that should require a CHANGELOG bump.
# Note: docs/, .claude/, .github/, scripts/, tests, and config files DON'T require CHANGELOG.
src_changed=$(echo "$all_changed_files" | grep -E '^(apps/(api|web)/src/|packages/[^/]+/src/)' | grep -vE '\.(test|spec)\.(ts|tsx|js)$' || true)

# If no source code touched, no CHANGELOG required.
if [ -z "$src_changed" ]; then
  echo "  ✓ no apps/**/src/ or packages/**/src/ files touched — CHANGELOG bump not required"
  exit 0
fi

# Source code touched — check if CHANGELOG was bumped in the same push range.
changelog_touched=$(echo "$all_changed_files" | grep -E '^docs/CHANGELOG\.md$' || true)

if [ -n "$changelog_touched" ]; then
  echo "  ✓ docs/CHANGELOG.md updated in push range — guard satisfied"
  # Belt-and-suspenders gate 4/4 (informational, non-blocking) — refresh
  # the operator-facing work-log token sheets. Primary trigger is the Stop
  # hook (Option A); this push-time pass catches sessions where Stop hook
  # missed (e.g. crashed, force-killed). See docs/observability/
  # work-log-schema-v2.md.
  if command -v python3 >/dev/null 2>&1 && [ -f "scripts/rebuild-work-log-tokens.py" ]; then
    echo "→ pre-push gate 5/5 (informational): refresh work-log token sheets"
    python3 scripts/rebuild-work-log-tokens.py 2>/dev/null && echo "  ✓ work-log Tokens — sheets refreshed" || echo "  (skipped — script error; non-blocking)"
  fi
  exit 0
fi

# Failed: source touched without CHANGELOG bump.
echo ""
echo "✗ pre-push CHANGELOG guard FAILED"
echo ""
echo "  Source files in this push range touch apps/**/src/ or packages/**/src/:"
echo "$src_changed" | head -10 | sed 's/^/    · /'
echo ""
echo "  But docs/CHANGELOG.md was NOT updated in any commit in this push range."
echo ""
echo "  Fix one of:"
echo "    (a) Run /changelog-add to capture the most recent commit, then commit + retry push."
echo "    (b) Manually edit docs/CHANGELOG.md [Unreleased] section, commit as docs(changelog), retry push."
echo "    (c) If this is genuinely doc-only / config-only / test-only and the filter above misclassified, bypass with: git push --no-verify (and document in EOD)."
echo ""
exit 1
