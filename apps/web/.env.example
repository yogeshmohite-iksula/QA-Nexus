# FE env vars — placeholders only, NEVER paste real values here.
# Copy to `apps/web/.env.local` (gitignored) and fill in for local dev.

# API origin (NestJS BE). Local dev defaults to http://localhost:3001.
# Production: set on Cloudflare Pages → qa-nexus-web → Variables and
# Secrets to https://qa-nexus-api.onrender.com. Hardcoded fallback in
# apps/web/lib/auth/client.ts (PR #122) covers the Cloudflare Pages
# NEXT_PUBLIC_* injection quirk (followup (be)).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# FE origin (where this Next.js app is served). Used by cross-origin
# BetterAuth callbackURLs (signIn.magicLink absolute redirect target).
# Production: https://qa-nexus-web.pages.dev. Hardcoded fallback in
# apps/web/lib/env.ts mirrors the API baseURL pattern from PR #122.
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
