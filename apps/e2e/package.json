{
  "name": "@qa-nexus/e2e",
  "version": "0.0.1",
  "private": true,
  "description": "QA Nexus PM1 — Playwright E2E smoke tests (MS0-T031)",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "install:browsers": "playwright install --with-deps chromium",
    "lint": "echo 'no lint config — playwright tests linted via root eslint flat config'",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.3.1",
    "typescript": "^5.6.3"
  }
}
