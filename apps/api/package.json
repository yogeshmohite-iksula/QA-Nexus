{
  "name": "@qa-nexus/api",
  "version": "0.0.1",
  "description": "QA Nexus PM1 — NestJS API service (REST + WebSocket; Prisma + BetterAuth + LLM gateway + embedding service)",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "pnpm --filter @qa-nexus/shared build && prisma generate && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "pnpm --filter @qa-nexus/shared build && prisma generate && tsc --noEmit -p tsconfig.json",
    "test": "prisma generate && jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:smoke": "jest --config ./test/jest-e2e.json --testPathPattern=smoke --passWithNoTests",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "prisma:apply-raw": "prisma db execute --file prisma/raw/init_rls_hnsw.sql --schema prisma/schema.prisma",
    "prisma:apply-raw:0002": "prisma db execute --file prisma/raw/migrations/0002_vector_384_dim.sql --schema prisma/schema.prisma",
    "prisma:apply-raw:0003": "prisma db execute --file prisma/raw/migrations/0003_users_disabled_at.sql --schema prisma/schema.prisma",
    "verify:audit": "ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' ../../scripts/verify-audit-chain.ts"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@google/generative-ai": "^0.24.0",
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-ws": "^10.0.0",
    "@nestjs/websockets": "^10.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.216.0",
    "@opentelemetry/auto-instrumentations-node": "^0.74.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.216.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.216.0",
    "@opentelemetry/sdk-node": "^0.216.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/client": "5.22.0",
    "@qa-nexus/shared": "workspace:*",
    "@xenova/transformers": "^2.17.2",
    "better-auth": "~1.2.0",
    "csv-parse": "^6.2.1",
    "express": "^5.0.0",
    "groq-sdk": "^0.7.0",
    "nodemailer": "^8.0.7",
    "pdf-parse": "^2.4.5",
    "reflect-metadata": "^0.2.0",
    "resend": "^4.0.0",
    "rxjs": "^7.8.1",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^6.0.0",
    "@types/ws": "^8.5.13",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "prisma": "5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.13.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
