# apps/api/.env.example — QA Nexus API service environment template
#
# Copy this to apps/api/.env (gitignored) for local development. For
# production, the real values live in Render's dashboard env-vars panel —
# NEVER commit production values to the repo.
#
# Each section below points at a runbook with step-by-step provisioning
# instructions and the EXACT values to paste into the upstream provider.

# ─────────────────────────────────────────────────────────────
# Database (Postgres 15 + pgvector on Neon free)
# Provisioned: MS0-T012 (Day 0). Runbook: docs/deploy/neon-runbook.md (TBD)
# ─────────────────────────────────────────────────────────────
# Pooled connection — used by runtime queries from NestJS handlers.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/qa_nexus_pm1?sslmode=require

# Direct (non-pooled) connection — required for `prisma migrate dev` because
# pgBouncer doesn't support Prisma's prepared statements. For PM1 pilot
# (single dyno), DIRECT_URL = DATABASE_URL is acceptable; revisit at PM2 scale.
DIRECT_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/qa_nexus_pm1?sslmode=require

# ─────────────────────────────────────────────────────────────
# Auth (BetterAuth Postgres adapter, magic-link via Resend)
# Provisioned: MS0-T021 (Day 2 evening). Runbook: docs/deploy/render-runbook.md
# ─────────────────────────────────────────────────────────────
# Generate via: openssl rand -base64 32
# Each environment (dev/staging/prod) gets its OWN secret. Never reuse.
BETTER_AUTH_SECRET=<generate-via-openssl-rand-base64-32>

# Set to the FULL Render service URL after first deploy (no trailing slash).
# Example: https://qa-nexus-api.onrender.com
# Staging: https://qa-nexus-api-staging.onrender.com
# Local dev: http://localhost:3001
BETTER_AUTH_URL=https://qa-nexus-api.onrender.com

# ─────────────────────────────────────────────────────────────
# Cookie domain (M1 T021 + ADR-007).
# ─────────────────────────────────────────────────────────────
# When set, BetterAuth issues session cookies with Domain=<value>.
# Production / custom domain: .qanexus.iksula.com (wildcard parent
# so app.* and api.* subdomains share session — see ADR-007).
# Staging on *.onrender.com OR localhost: leave UNSET — auth.config.ts
# auto-handles the localhost dev guard + secure-cookies flip.
BETTER_AUTH_COOKIE_DOMAIN=

# ─────────────────────────────────────────────────────────────
# Day-0 admin seed (M1 T021).
# ─────────────────────────────────────────────────────────────
# On first magic-link sign-in matching this email, AuthService
# auto-creates a TB-002 user row with role=Admin in the seeded
# Iksula workspace + writes a `day0_admin_seeded` audit row.
# Closes followup (x). Idempotent: re-runs are no-op.
ADMIN_SEED_EMAIL=yogesh.mohite@iksula.com

# ─────────────────────────────────────────────────────────────
# LLM gateway (Groq primary + Gemini fallback)
# Provisioned: MS0-T023 (BE chat, in flight Day 3). Runbook: docs/deploy/render-runbook.md § "Env vars"
# ─────────────────────────────────────────────────────────────
# Primary chain — defaults set by BE chat once T023 lands. Examples:
LLM_PRIMARY_PROVIDER=groq
LLM_PRIMARY_MODEL=openai/gpt-oss-120b
LLM_PRIMARY_API_KEY=<set-after-T023-via-https://console.groq.com/keys>

# Secondary fallback chain
LLM_SECONDARY_PROVIDER=gemini
LLM_SECONDARY_MODEL=gemini-2.5-flash
LLM_SECONDARY_API_KEY=<set-after-T023-via-https://aistudio.google.com/apikey>

# Long-context overflow chain (optional, for >100k token requests)
LLM_LONG_CONTEXT_PROVIDER=groq
LLM_LONG_CONTEXT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
LLM_LONG_CONTEXT_THRESHOLD_TOKENS=100000

# ─────────────────────────────────────────────────────────────
# Email (Resend free tier)
# Provisioned: MS0-T014 (Day 3 dashboard work). Runbook: docs/deploy/resend-runbook.md
# ─────────────────────────────────────────────────────────────
# When unset, EmailService falls back to STUB MODE (logs to console). Magic-link
# flow works in dev without this; production REQUIRES it.
RESEND_API_KEY=<set-after-T014-via-https://resend.com/api-keys>

# ─────────────────────────────────────────────────────────────
# Storage (Cloudflare R2 free tier)
# Provisioned: MS0-T013 (Day 3 dashboard work). Runbook: docs/deploy/r2-runbook.md
# ─────────────────────────────────────────────────────────────
# When unset, /storage endpoints return 503 and /health reports r2.status="deferred".
R2_ACCESS_KEY_ID=<set-after-T013-via-cf-dashboard-r2-tokens>
R2_SECRET_ACCESS_KEY=<set-after-T013-via-cf-dashboard-r2-tokens>
R2_BUCKET=qa-nexus-evidence-pm1
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# ─────────────────────────────────────────────────────────────
# Embedding model (in-process via @xenova/transformers)
# Provisioned: MS0-T024 (Day 2 stretch). ADR: docs/architecture/adr-003-embedding-model.md
# ─────────────────────────────────────────────────────────────
# Default = bge-large-en-v1.5 (1024-dim, ONNX-converted by Xenova). Hot-swap to
# Qwen3-Embedding-0.6B once Xenova ships the conversion (per ADR-003 §"Hot-swap path").
EMBEDDING_MODEL_ID=Xenova/bge-large-en-v1.5

# ─────────────────────────────────────────────────────────────
# App config
# ─────────────────────────────────────────────────────────────
NODE_ENV=production  # local dev: development
PORT=3001            # Render sets $PORT automatically; this is the local-dev fallback

# ─────────────────────────────────────────────────────────────
# Observability (T019 — Path 2 pure-OTel pipeline, no pino)
# ─────────────────────────────────────────────────────────────
# All four vars are OPTIONAL. Service runs in deferred-mode when unset
# (logs go to stdout only, /health reports otel.{traces,logs}.exporter
# = "deferred"). Set after Yogesh provisions Grafana Cloud + Better
# Stack. See:
#   - docs/deploy/render-runbook.md (env-var section)
#   - docs/deploy/better-stack-runbook.md (Better Stack source setup)
#
# Grafana Cloud OTLP — TRACES + METRICS (configure source as
# "OpenTelemetry / OTLP HTTP" in Grafana Cloud's Connections tab).
# GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-us-central-0.grafana.net/otlp
# GRAFANA_CLOUD_OTLP_AUTH=<base64(grafana_user:grafana_api_token)>

# Better Stack OTLP — LOGS (create Better Stack source with type
# "OpenTelemetry", NOT "Pino" or "Generic"; copy OTLP HTTP endpoint +
# Bearer token from the source's Connect panel).
# BETTER_STACK_OTLP_ENDPOINT=https://in-otel.logs.betterstack.com
# BETTER_STACK_OTLP_AUTH=<source_token_from_better_stack>

# ─────────────────────────────────────────────────────────────
# Day-25 deploy-readiness sync (2026-05-24) — add vars that exist
# in code (process.env.X across apps/api/src) but were missing from
# this example file. Surfaced by .claude/scratch/m5-deployment-readiness.md
# investigation. ALL values are PLACEHOLDERS per .claude/rules/security.md
# — real values live ONLY in Render dashboard env-vars panel (production)
# and your local apps/api/.env (gitignored, for dev).
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
# Direct provider API keys (parallel to LLM_PRIMARY_API_KEY)
# ─────────────────────────────────────────────────────────────
# Some code paths read provider keys directly (vs through LLM_*_API_KEY
# which is the ADR-015 runtime-config path). Set both for safety —
# pasting the same key into both is fine.
# GROQ_API_KEY=<get-from-https://console.groq.com/keys>
# GEMINI_API_KEY=<get-from-https://aistudio.google.com/apikey>
# GOOGLE_API_KEY=<alias-for-GEMINI_API_KEY-used-by-@google/generative-ai-sdk>

# ─────────────────────────────────────────────────────────────
# CORS / trusted-origin allowlists
# ─────────────────────────────────────────────────────────────
# Comma-separated. Required in production; leave unset for local dev
# (auth.config.ts auto-handles localhost). Example values:
#   AUTH_TRUSTED_ORIGINS=https://qa-nexus-web.pages.dev,https://qanexus.iksula.com
#   ALLOWED_WS_ORIGINS=https://qa-nexus-web.pages.dev,https://qanexus.iksula.com
#   TRUSTED_CALLBACK_ORIGINS=https://qa-nexus-web.pages.dev,https://qa-nexus-api.onrender.com
# AUTH_TRUSTED_ORIGINS=
# ALLOWED_WS_ORIGINS=
# TRUSTED_CALLBACK_ORIGINS=

# Frontend base URL — used for absolute links in emails (magic-link,
# invite-accept). Production: https://qa-nexus-web.pages.dev. Local: http://localhost:3000.
# FRONTEND_BASE_URL=https://qa-nexus-web.pages.dev

# Base URL for invitation-accept links generated by InvitesService.
# Typically = FRONTEND_BASE_URL + /invite/accept.
# INVITATION_ACCEPT_URL_BASE=https://qa-nexus-web.pages.dev/invite/accept

# ─────────────────────────────────────────────────────────────
# WebSocket gateway limits (MS0-T026)
# ─────────────────────────────────────────────────────────────
# Default = 1000. PM1 pilot (8 users × ~3 sessions) needs well below this.
# MAX_WS_CONNECTIONS=1000

# ─────────────────────────────────────────────────────────────
# Email — Resend identity + SMTP fallback
# ─────────────────────────────────────────────────────────────
# RESEND_* config the EmailService reads (in addition to RESEND_API_KEY
# above). Per ADR-018 we use Resend HTTPS API not SMTP — SMTP_* vars are
# legacy fallback paths kept for stub-mode testing only.
# RESEND_FROM_EMAIL=noreply@qanexus.iksula.com
# RESEND_FROM_NAME=QA Nexus
# RESEND_REPLY_TO=yogesh.mohite@iksula.com
# RESEND_BCC_EMAIL=<optional-audit-bcc-mailbox>
# SMTP_HOST=<legacy-only-leave-unset-for-Resend-path>
# SMTP_USER=<legacy-only-leave-unset-for-Resend-path>

# ─────────────────────────────────────────────────────────────
# Jira webhook (HMAC verification per ADR-020)
# ─────────────────────────────────────────────────────────────
# Shared secret with Atlassian's webhook config. Set the SAME value in
# the Jira webhook UI (Settings → System → Webhooks → secret field).
# Required in production; without it, POST /webhooks/jira returns 401.
# JIRA_WEBHOOK_SECRET=<generate-via-openssl-rand-hex-32>

# ─────────────────────────────────────────────────────────────
# Feature flags / debug toggles
# ─────────────────────────────────────────────────────────────
# All default to false / off in code. Set to "1" or "true" to enable.
#
# LLM_DEBUG=                    # Verbose console logging of LLM prompts + responses (dev only — NEVER set in prod)
# COMPOSER_OFFLINE=             # Composer agent returns canned responses instead of calling LLM (e2e test mode)
# CURATOR_OFFLINE=              # Curator agent returns canned responses instead of calling LLM (e2e test mode)
# EMAIL_TEST_CAPTURE=           # Capture outgoing emails to memory instead of sending (e2e test mode)
# ALLOW_ADMIN_OTEL_TEST=        # Enable /admin/otel-test debug endpoint (dev/staging only)
