// QA Nexus PM1 — Prisma schema
// =============================================================================
// Spec: PM1_ERD §3 (TB-001..TB-021) — see QA Nexus/PM1/PM1_ERD/PM1_ERD.md
// Rules: .claude/rules/database.md (binding) + .claude/memory/tools/database.md
// Task: MS0-T020 (Day 2). Migration deferred until Yogesh provisions Neon DB.
//
// Authoring decisions (documented in PR + docs/parallel-work/chat3-status-day2.md):
//   1. Vector dim = 384 (Xenova/bge-small-en-v1.5). Original choice was
//      1024 (Qwen3-Embedding-0.6B) overriding ERD §5's vector(384), but the
//      Day-4 afternoon Render Free 512 MB OOM forced a swap back to bge-small
//      per ADR-003 amendment + ADR-009. Schema migration:
//      apps/api/prisma/raw/migrations/0002_vector_384_dim.sql (Day-5).
//      bge-large will return as a hot-swap when off Free tier — see
//      followup (l) for the M3 quality eval methodology that gates that swap.
//   2. Table names: plural snake_case (workspaces, users, ...) per
//      database.md hard rule, mapped from PascalCase singular Prisma models
//      via @@map.
//   3. workspaces.created_by NULL initially to break the
//      workspaces ↔ users circular FK; backfilled by seed script (§3.8
//      Day-0 Workspace Bootstrap).
//   4. audit_log + agent_run columns are NOT in ERD §5 ("auxiliary"). Designed
//      from policy in database.md + CLAUDE.md Hard Rule 7. agent_run is a
//      first-pass minimum; refine in M3 when A1/A2/A4 specs solidify.
//   5. kb_documents.template_kind = text (not enum) — ERD doesn't enumerate
//      the 12 PM1 templates. Enum-ify in M2 when KB templates land.
//   6. BetterAuth integration deferred to MS0-T021. This schema defines users
//      per ERD TB-002 (with password_hash); T021 will configure BetterAuth
//      Postgres adapter to use this table OR add a parallel auth-shadow
//      table — that's a T021 design call, not T020.
//   7. Token-encryption columns (jira_connections.oauth_*_token_encrypted,
//      llm_providers.api_key_encrypted) are plain `text` here. App-layer
//      AES-GCM with BETTER_AUTH_SECRET is added in T013/T021. Vault is on
//      kickoff §6 ban list — explicitly NOT used.
//   8. RLS policies, HNSW indexes, audit_log triggers, pgvector extension
//      are in apps/api/prisma/migrations/0_init_rls_hnsw/migration.sql
//      because Prisma 5 cannot express them.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")]
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  Admin
  Lead
  QAEngineer
  Stakeholder

  @@map("user_role")
}

enum InvitationStatus {
  pending
  accepted
  expired
  revoked

  @@map("invitation_status")
}

enum Priority {
  P0
  P1
  P2
  P3

  @@map("priority")
}

enum RequirementStatus {
  draft
  active
  done
  archived

  @@map("requirement_status")
}

enum RequirementSource {
  manual
  jira
  upload

  @@map("requirement_source")
}

enum TestCaseStatus {
  ai_draft
  manual_draft
  reviewed
  active
  flaky
  deprecated

  @@map("test_case_status")
}

enum TestSuiteStatus {
  healthy
  warning
  stale
  archived

  @@map("test_suite_status")
}

enum RunTrigger {
  manual
  webhook
  cron

  @@map("run_trigger")
}

enum TestRunStatus {
  queued
  running
  passed
  failed
  blocked
  aborted

  @@map("test_run_status")
}

enum TestResultStatus {
  passed
  failed
  blocked
  skipped

  @@map("test_result_status")
}

enum JiraAuthMethod {
  oauth_3lo
  // M4 (Day-18 #144) — Atlassian API token auth, simpler bootstrap path
  // for the pilot vs full OAuth 3LO. Discriminated by JiraConnection.
  // authMethod; account_email is REQUIRED in this branch.
  api_token

  @@map("jira_auth_method")
}

enum JiraConnectionStatus {
  active
  expired
  revoked

  @@map("jira_connection_status")
}

enum DefectStatus {
  new
  triaged
  in_progress
  resolved
  verified
  closed
  reopened
  blocked

  @@map("defect_status")
}

enum LlmProviderKind {
  groq
  gemini
  openrouter
  cerebras
  openai
  anthropic
  kimi
  mistral
  together
  fireworks
  custom_oai

  @@map("llm_provider_kind")
}

enum LlmProviderStatus {
  connected
  error
  unverified

  @@map("llm_provider_status")
}

enum AgentKind {
  A1
  A2
  A4

  @@map("agent_kind")
}

enum AgentRole {
  primary
  long_context
  fallback
  fast_layer

  @@map("agent_role")
}

enum AgentRunStatus {
  queued
  running
  complete
  failed

  @@map("agent_run_status")
}

// =============================================================================
// CORE TABLES (TB-001..TB-021 + auxiliary audit_log, agent_run)
// =============================================================================

/// TB-001 — top-level tenant container ("Iksula" for the pilot).
/// NOT RLS-scoped (it IS the workspace).
model Workspace {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  // Nullable to break the workspaces ↔ users circular FK; backfilled by seed.
  createdBy String?  @map("created_by") @db.Uuid
  settings  Json     @default("{}") @db.JsonB

  creator               User?                  @relation("WorkspaceCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  users                 User[]                 @relation("WorkspaceUsers")
  projects              Project[]
  invitations           UserInvitation[]
  llmProviders          LlmProvider[]
  agentModelAssignments AgentModelAssignment[]
  auditLogs             AuditLog[]
  agentRuns             AgentRun[]

  @@map("workspaces")
}

/// TB-002 — individual account (8 named pilot users).
/// Has workspace_id FK but is RLS-exempt (top-level lookup).
model User {
  id                  String    @id @default(uuid()) @db.Uuid
  workspaceId         String    @map("workspace_id") @db.Uuid
  email               String    @unique
  displayName         String    @map("display_name")
  role                UserRole
  organizationalLabel String?   @map("organizational_label")
  passwordHash        String    @map("password_hash") // argon2id
  activatedAt         DateTime? @map("activated_at") @db.Timestamptz(6)
  /// M1 — Day-6 PM. NULL = active or invited (per derivation in
  /// UsersService.deriveStatus); set to disable + revoke sessions.
  /// Schema delta: apps/api/prisma/raw/migrations/0003_users_disabled_at.sql
  disabledAt          DateTime? @map("disabled_at") @db.Timestamptz(6)
  /// M1 — Day-6 PM. Stamped whenever role transitions via PATCH
  /// /api/users/:id/role. Surfaced via UserDetailResponse for F27.
  roleChangedAt       DateTime? @map("role_changed_at") @db.Timestamptz(6)
  lastLoginAt         DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace                       Workspace               @relation("WorkspaceUsers", fields: [workspaceId], references: [id], onDelete: Cascade)
  workspacesCreated               Workspace[]             @relation("WorkspaceCreator")
  projectsCreated                 Project[]               @relation("ProjectCreator")
  projectMemberships              ProjectMember[]
  invitationsSent                 UserInvitation[]        @relation("InvitedBy")
  requirementsCreated             Requirement[]
  testCasesCreated                TestCase[]
  testSuitesOwned                 TestSuite[]
  testRunsTriggered               TestRun[]               @relation("TestRunTriggeredBy")
  defectsAssigned                 Defect[]                @relation("DefectAssignee")
  kbDocumentsAuthored             KbDocument[]
  llmProvidersCreated             LlmProvider[]
  agentAssignmentsCreated         AgentModelAssignment[]
  auditActions                    AuditLog[]
  testCaseGenerationRunsTriggered TestCaseGenerationRun[] @relation("TestCaseGenerationRunTriggerer")
  /// M4 (Day-18 #144)
  evidenceCreated                 Evidence[]              @relation("EvidenceCreator")
  defectHistoryActions            DefectHistory[]         @relation("DefectHistoryActor")

  @@index([workspaceId])
  @@map("users")
}

/// TB-003 — a QA project within a workspace ("Iksula Returns", key "RET").
/// RLS-scoped via workspace_id.
model Project {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  key         String
  name        String
  description String?
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace              Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator                User                    @relation("ProjectCreator", fields: [createdBy], references: [id])
  members                ProjectMember[]
  requirements           Requirement[]
  testCases              TestCase[]
  testSuites             TestSuite[]
  testRuns               TestRun[]
  jiraConnections        JiraConnection[]
  defects                Defect[]
  kbDocuments            KbDocument[]
  testCaseGenerationRuns TestCaseGenerationRun[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@map("projects")
}

/// TB-004 — per-project user assignment with optional role override.
/// RLS via parent project.
model ProjectMember {
  projectId    String    @map("project_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  roleOverride UserRole? @map("role_override")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

/// TB-005 — pending magic-link invites + password resets.
/// RLS via workspace_id.
model UserInvitation {
  id               String           @id @default(uuid()) @db.Uuid
  workspaceId      String           @map("workspace_id") @db.Uuid
  invitedEmail     String           @map("invited_email")
  role             UserRole
  projectScopeJson Json             @default("[]") @map("project_scope_json") @db.JsonB
  invitedBy        String           @map("invited_by") @db.Uuid
  tokenHash        String           @map("token_hash")
  expiresAt        DateTime         @map("expires_at") @db.Timestamptz(6)
  status           InvitationStatus @default(pending)
  acceptedAt       DateTime?        @map("accepted_at") @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inviter   User      @relation("InvitedBy", fields: [invitedBy], references: [id])

  @@index([workspaceId])
  @@index([invitedEmail])
  @@map("user_invitations")
}

/// TB-006 — imported/manual requirements (Jira RET-### or upload REQ-###).
/// RLS via project.
model Requirement {
  id          String            @id @default(uuid()) @db.Uuid
  projectId   String            @map("project_id") @db.Uuid
  key         String
  title       String
  description String
  epicKey     String?           @map("epic_key")
  priority    Priority
  status      RequirementStatus @default(draft)
  sprint      String?
  source      RequirementSource @default(manual)
  sourceRef   String?           @map("source_ref")
  createdBy   String            @map("created_by") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  project                Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator                User                    @relation(fields: [createdBy], references: [id])
  testCaseLinks          TestCaseLink[]
  jiraIssues             JiraIssue[]             @relation("JiraIssueRequirement")
  testCaseGenerationRuns TestCaseGenerationRun[]

  @@unique([projectId, key])
  @@index([projectId])
  @@map("requirements")
}

/// TB-007 — test case records (AI-generated or manual).
/// RLS via project. Has 384-dim vector embedding (HNSW index in raw SQL).
model TestCase {
  id               String                      @id @default(uuid()) @db.Uuid
  projectId        String                      @map("project_id") @db.Uuid
  key              String
  title            String
  preconditions    String                      @default("")
  stepsJson        Json                        @default("[]") @map("steps_json") @db.JsonB
  expectedResult   String                      @map("expected_result")
  priority         Priority
  status           TestCaseStatus              @default(ai_draft)
  confidenceScore  Float?                      @map("confidence_score")
  aiProvenanceJson Json?                       @map("ai_provenance_json") @db.JsonB
  /// M3 TASK BE-01 — AI provenance columns. `format='step'` uses
  /// stepsJson (existing); `format='gherkin'` uses `gherkin` text body.
  /// `generatedByAgent` = 'composer' / 'curator' / null (manual).
  /// `sourceChunkIds` = JSONB array of kb_chunk UUIDs that grounded
  /// the generation (Composer RAG); `rationale` = LLM-rendered "why
  /// this test case" surfaced in F31 review modal.
  format           String                      @default("step")
  gherkin          String?
  generatedByAgent String?                     @map("generated_by_agent")
  sourceChunkIds   Json?                       @map("source_chunk_ids") @db.JsonB
  rationale        String?
  /// 384-dim Xenova/bge-small-en-v1.5 vector. HNSW (vector_cosine_ops, m=16,
  /// ef_construction=64) index added in raw SQL migration. Per ADR-003
  /// amendment + ADR-009 (Render Free 512 MB constraint). Migration:
  /// apps/api/prisma/raw/migrations/0002_vector_384_dim.sql (Day-5).
  embedding        Unsupported("vector(384)")?
  createdBy        String                      @map("created_by") @db.Uuid
  createdAt        DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator          User              @relation(fields: [createdBy], references: [id])
  requirementLinks TestCaseLink[]
  suiteMembers     TestSuiteMember[]
  runResults       TestRunResult[]
  defectsTriggered Defect[]          @relation("DefectTriggeredByTestCase")

  @@unique([projectId, key])
  @@index([projectId])
  @@index([projectId, format], map: "idx_test_cases_format")
  @@map("test_cases")
}

/// TB-022 (NEW for M3) — one row per Composer run.
/// Spec: Milestone_M3_Test_Cases_AI_v2.md §TB-022.
/// Lifecycle: row inserted on Composer trigger, status updated as run
/// progresses through retrieval → generation → user review.
model TestCaseGenerationRun {
  id                 String   @id @default(uuid()) @db.Uuid
  projectId          String   @map("project_id") @db.Uuid
  /// Optional — Composer can be invoked without a specific requirement
  /// (free-form prompt mode). NULL also when a requirement is later
  /// deleted (ON DELETE SET NULL per migration).
  requirementId      String?  @map("requirement_id") @db.Uuid
  triggeredBy        String   @map("triggered_by") @db.Uuid
  /// 'groq' | 'gemini' (CHECK constraint enforces in raw SQL).
  llmProvider        String   @map("llm_provider")
  llmModel           String   @map("llm_model")
  inputTokenCount    Int      @default(0) @map("input_token_count")
  outputTokenCount   Int      @default(0) @map("output_token_count")
  chunksRetrieved    Int      @default(0) @map("chunks_retrieved")
  casesGenerated     Int      @default(0) @map("cases_generated")
  /// NULL until user accepts/rejects in F31 review modal.
  casesAccepted      Int?     @map("cases_accepted")
  /// NULL until Curator dedupe pass runs (post-generation).
  casesDedupeFlagged Int?     @map("cases_dedupe_flagged")
  durationMs         Int      @map("duration_ms")
  /// 'success' | 'partial' | 'failed' (CHECK constraint enforces).
  status             String
  /// Truncated to ~500 chars in app code (mirrors kb_search_failed).
  errorReason        String?  @map("error_reason")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirement Requirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  triggerer   User         @relation("TestCaseGenerationRunTriggerer", fields: [triggeredBy], references: [id])

  @@index([projectId, createdAt(sort: Desc)], map: "idx_tcgr_project_created")
  @@index([triggeredBy], map: "idx_tcgr_triggered_by")
  @@map("test_case_generation_runs")
}

/// TB-008 — M:N join: test_case ↔ requirement.
/// RLS transitive via parents.
model TestCaseLink {
  testCaseId    String @map("test_case_id") @db.Uuid
  requirementId String @map("requirement_id") @db.Uuid

  testCase    TestCase    @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@id([testCaseId, requirementId])
  @@index([requirementId])
  @@map("test_case_links")
}

/// TB-009 — named bundle of test cases.
/// RLS via project.
model TestSuite {
  id          String          @id @default(uuid()) @db.Uuid
  projectId   String          @map("project_id") @db.Uuid
  name        String
  description String          @default("")
  ownerId     String          @map("owner_id") @db.Uuid
  status      TestSuiteStatus @default(healthy)
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   User              @relation(fields: [ownerId], references: [id])
  members TestSuiteMember[]
  runs    TestRun[]

  @@index([projectId])
  @@map("test_suites")
}

/// TB-010 — ordered M:N join: suite ↔ test_case.
/// RLS transitive via parents.
model TestSuiteMember {
  suiteId      String @map("suite_id") @db.Uuid
  testCaseId   String @map("test_case_id") @db.Uuid
  displayOrder Int    @map("display_order")

  suite    TestSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  testCase TestCase  @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@id([suiteId, testCaseId])
  @@index([testCaseId])
  @@map("test_suite_members")
}

/// TB-011 — a single execution of a suite/cases.
/// RLS via project.
model TestRun {
  id                String        @id @default(uuid()) @db.Uuid
  projectId         String        @map("project_id") @db.Uuid
  suiteId           String?       @map("suite_id") @db.Uuid
  name              String
  triggeredBy       RunTrigger    @map("triggered_by")
  triggeredByUserId String?       @map("triggered_by_user") @db.Uuid
  status            TestRunStatus @default(queued)
  startedAt         DateTime?     @map("started_at") @db.Timestamptz(6)
  completedAt       DateTime?     @map("completed_at") @db.Timestamptz(6)
  environment       String

  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  suite            TestSuite?      @relation(fields: [suiteId], references: [id], onDelete: SetNull)
  triggeredByUser  User?           @relation("TestRunTriggeredBy", fields: [triggeredByUserId], references: [id])
  results          TestRunResult[]
  defectsTriggered Defect[]        @relation("DefectTriggeredByRun")

  @@index([projectId])
  @@index([suiteId])
  @@map("test_runs")
}

/// TB-012 — per-case outcome within a run.
/// RLS transitive via parent run.
model TestRunResult {
  id             String           @id @default(uuid()) @db.Uuid
  runId          String           @map("run_id") @db.Uuid
  testCaseId     String           @map("test_case_id") @db.Uuid
  status         TestResultStatus
  durationMs     Int              @map("duration_ms")
  evidenceUri    String?          @map("evidence_uri")
  failureMessage String?          @map("failure_message")
  stackTrace     String?          @map("stack_trace")
  /// M4 (Day-18 #144) — what the tester actually saw during execution.
  /// Free text. Surfaces in F20 Run Results detail panel.
  actualResult   String?          @map("actual_result")
  /// M4 (Day-18 #144) — JSONB array of evidence.id UUIDs attached to this
  /// execution. Denormalized for fast lookup; canonical source is
  /// evidence.test_run_result_id.
  evidenceIds    Json             @default("[]") @map("evidence_ids") @db.JsonB
  /// M4 (Day-18 #144) — when status=blocked, required free-text reason.
  /// Drives F20 + A4 RCA L1 (environment context). App-layer enforced.
  blockedReason  String?          @map("blocked_reason")

  run      TestRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  testCase TestCase   @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  /// M4 (Day-18 #144)
  evidence Evidence[]

  @@index([runId])
  @@index([testCaseId])
  @@map("test_run_results")
}

/// TB-013 — OAuth 3LO state for an Iksula Atlassian project.
/// RLS via project. PM1 = OAuth 3LO only; PM3 adds api_token / pat / custom_oauth.
/// Token columns hold AES-GCM-encrypted payloads (encrypt at app layer with
/// BETTER_AUTH_SECRET — Vault is on the ban-list).
model JiraConnection {
  id                         String               @id @default(uuid()) @db.Uuid
  projectId                  String               @map("project_id") @db.Uuid
  authMethod                 JiraAuthMethod       @default(oauth_3lo) @map("auth_method")
  jiraBaseUrl                String               @map("jira_base_url")
  /// Holds OAuth access token (oauth_3lo) OR Atlassian API token (api_token),
  /// distinguished by `authMethod`. AES-GCM ciphertext via crypto.ts (PR #115).
  oauthAccessTokenEncrypted  String               @map("oauth_access_token_encrypted")
  oauthRefreshTokenEncrypted String               @map("oauth_refresh_token_encrypted")
  oauthExpiresAt             DateTime             @map("oauth_expires_at") @db.Timestamptz(6)
  status                     JiraConnectionStatus @default(active)
  lastSyncAt                 DateTime?            @map("last_sync_at") @db.Timestamptz(6)
  /// M4 (Day-18 #144) — per-integration Jira-status → defect_status map.
  /// `{}` = use default mapping. Surfaces in F26 admin config.
  statusMapping              Json                 @default("{}") @map("status_mapping") @db.JsonB
  /// M4 (Day-18 #144) — REQUIRED when authMethod=api_token; the Atlassian
  /// account whose API token is in oauth_access_token_encrypted. NULL when
  /// authMethod=oauth_3lo (BetterAuth tracks user identity instead).
  accountEmail               String?              @map("account_email")

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues   JiraIssue[]
  syncLogs JiraSyncLog[]

  @@index([projectId])
  @@map("jira_connections")
}

/// TB-014 — mirror of issues sync'd from Jira.
/// RLS transitive via parent connection → project.
model JiraIssue {
  id                  String   @id @default(uuid()) @db.Uuid
  jiraConnectionId    String   @map("jira_connection_id") @db.Uuid
  jiraKey             String   @map("jira_key")
  issueType           String   @map("issue_type")
  status              String
  linkedDefectId      String?  @map("linked_defect_id") @db.Uuid
  linkedRequirementId String?  @map("linked_requirement_id") @db.Uuid
  lastSyncedAt        DateTime @map("last_synced_at") @db.Timestamptz(6)

  jiraConnection    JiraConnection @relation(fields: [jiraConnectionId], references: [id], onDelete: Cascade)
  linkedDefect      Defect?        @relation("JiraIssueDefect", fields: [linkedDefectId], references: [id], onDelete: SetNull)
  linkedRequirement Requirement?   @relation("JiraIssueRequirement", fields: [linkedRequirementId], references: [id], onDelete: SetNull)

  @@unique([jiraConnectionId, jiraKey])
  @@index([linkedDefectId])
  @@index([linkedRequirementId])
  @@map("jira_issues")
}

/// TB-015 — bug records (PM1 defect lifecycle).
/// RLS via project.
model Defect {
  id                    String       @id @default(uuid()) @db.Uuid
  projectId             String       @map("project_id") @db.Uuid
  key                   String
  title                 String
  description           String
  severity              Priority
  status                DefectStatus @default(new)
  triggeredByRunId      String?      @map("triggered_by_run_id") @db.Uuid
  triggeredByTestCaseId String?      @map("triggered_by_test_case_id") @db.Uuid
  assigneeId            String?      @map("assignee_id") @db.Uuid
  jiraIssueId           String?      @map("jira_issue_id") @db.Uuid
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt            DateTime?    @map("resolved_at") @db.Timestamptz(6)
  /// M4 (Day-18 #144) — free-text component label (e.g. "checkout-flow",
  /// "payments-gateway"). Drives F21 filter + A4 RCA L3 (recent commits).
  component             String?
  /// M4 (Day-18 #144) — stamped on resolved → verified transition.
  /// Surfaces "time-to-verify" SLA in F25 Executive Dashboard.
  verifiedAt            DateTime?    @map("verified_at") @db.Timestamptz(6)
  /// M4 (Day-18 #144) — stamped on verified → closed transition.
  /// Permanent terminal state; differs from resolved_at (dev-side fix-complete).
  closedAt              DateTime?    @map("closed_at") @db.Timestamptz(6)

  project             Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggeredByRun      TestRun?        @relation("DefectTriggeredByRun", fields: [triggeredByRunId], references: [id], onDelete: SetNull)
  triggeredByTestCase TestCase?       @relation("DefectTriggeredByTestCase", fields: [triggeredByTestCaseId], references: [id], onDelete: SetNull)
  assignee            User?           @relation("DefectAssignee", fields: [assigneeId], references: [id])
  rcaReports          RcaReport[]
  jiraIssues          JiraIssue[]     @relation("JiraIssueDefect")
  /// M4 (Day-18 #144)
  evidence            Evidence[]
  history             DefectHistory[]
  jiraSyncLogs        JiraSyncLog[]

  @@unique([projectId, key])
  @@index([projectId])
  @@index([assigneeId])
  @@map("defects")
}

/// TB-016 — 5-Layer RCA output for a defect (A4 agent).
/// RLS transitive via parent defect.
model RcaReport {
  id                  String   @id @default(uuid()) @db.Uuid
  defectId            String   @map("defect_id") @db.Uuid
  layer1StackJson     Json     @map("layer1_stack_json") @db.JsonB
  layer2EnvJson       Json     @map("layer2_env_json") @db.JsonB
  layer3ConfigJson    Json     @map("layer3_config_json") @db.JsonB
  layer4CodeJson      Json     @map("layer4_code_json") @db.JsonB
  layer5DataJson      Json     @map("layer5_data_json") @db.JsonB
  topHypothesis       String   @map("top_hypothesis")
  createdByAgentRunId String   @map("created_by_agent_run_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// M4 (Day-18 #144) — A4 5-layer confidence canon: L1=0.90 / L2=0.80 /
  /// L3=0.60 / L4=0.50 / L5=0.40 baseline. Runtime A4 computes per-defect
  /// actuals. CHECK constraint enforces 0.0-1.0 in raw migration SQL.
  layer1Confidence    Float?   @map("layer1_confidence") @db.DoublePrecision
  layer2Confidence    Float?   @map("layer2_confidence") @db.DoublePrecision
  layer3Confidence    Float?   @map("layer3_confidence") @db.DoublePrecision
  layer4Confidence    Float?   @map("layer4_confidence") @db.DoublePrecision
  layer5Confidence    Float?   @map("layer5_confidence") @db.DoublePrecision
  /// M4 (Day-18 #144) — OTel trace_id for the A4 Promise.all parallel
  /// orchestration. Permits Grafana drill-down from F21 RCA panel.
  otelTraceId         String?  @map("otel_trace_id")
  /// M4 (Day-18 #144) — user feedback {"rating":1-5, "correctLayer":1-5|null,
  /// "comment":text|null, "submittedBy":user.id, "submittedAt":timestamptz}.
  /// Drives DeepEval golden-set refresh.
  feedback            Json     @default("{}") @map("feedback") @db.JsonB

  defect            Defect   @relation(fields: [defectId], references: [id], onDelete: Cascade)
  createdByAgentRun AgentRun @relation(fields: [createdByAgentRunId], references: [id])

  @@index([defectId])
  @@map("rca_reports")
}

/// TB-017 — knowledge base documents (TipTap markdown body).
/// RLS via project; null project_id = workspace-scoped.
/// template_kind kept as text until M2 enumerates the 12 PM1 templates.
model KbDocument {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String?  @map("project_id") @db.Uuid
  title        String
  bodyMd       String   @map("body_md")
  templateKind String   @map("template_kind")
  pinned       Boolean  @default(false)
  authorId     String   @map("author_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  project Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id])
  chunks  KbChunk[]

  @@index([projectId])
  @@map("kb_documents")
}

/// TB-018 — chunked KB content for semantic search.
/// RLS transitive via parent document. 384-dim vector embedding.
model KbChunk {
  id           String                      @id @default(uuid()) @db.Uuid
  documentId   String                      @map("document_id") @db.Uuid
  chunkText    String                      @map("chunk_text")
  /// 384-dim Xenova/bge-small-en-v1.5 vector. HNSW index in raw SQL
  /// migration. Per ADR-003 amendment + ADR-009 (Day-5).
  embedding    Unsupported("vector(384)")?
  chunkIndex   Int                         @map("chunk_index")
  metadataJson Json                        @default("{}") @map("metadata_json") @db.JsonB

  document KbDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@map("kb_chunks")
}

/// TB-019 — per-workspace registered LLM provider credentials (F28m1).
/// RLS via workspace_id (Admin-only visibility per ERD §3 L940).
/// api_key_encrypted holds AES-GCM-encrypted payload (BETTER_AUTH_SECRET).
model LlmProvider {
  id              String            @id @default(uuid()) @db.Uuid
  workspaceId     String            @map("workspace_id") @db.Uuid
  providerKind    LlmProviderKind   @map("provider_kind")
  displayName     String            @map("display_name")
  apiKeyEncrypted String            @map("api_key_encrypted")
  endpointUrl     String            @map("endpoint_url")
  extraConfigJson Json              @default("{}") @map("extra_config_json") @db.JsonB
  status          LlmProviderStatus @default(unverified)
  lastTestAt      DateTime?         @map("last_test_at") @db.Timestamptz(6)
  lastTestResult  Json?             @map("last_test_result") @db.JsonB
  createdBy       String            @map("created_by") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User               @relation(fields: [createdBy], references: [id])
  models    LlmProviderModel[]

  @@index([workspaceId])
  @@map("llm_providers")
}

/// TB-020 — catalog of fetched models per provider.
/// RLS transitive via parent.
model LlmProviderModel {
  id                  String   @id @default(uuid()) @db.Uuid
  providerId          String   @map("provider_id") @db.Uuid
  modelId             String   @map("model_id")
  displayName         String   @map("display_name")
  capabilityJson      Json     @default("{}") @map("capability_json") @db.JsonB
  enabledForWorkspace Boolean  @default(true) @map("enabled_for_workspace")
  fetchedAt           DateTime @default(now()) @map("fetched_at") @db.Timestamptz(6)

  provider         LlmProvider            @relation(fields: [providerId], references: [id], onDelete: Cascade)
  agentAssignments AgentModelAssignment[]

  @@unique([providerId, modelId])
  @@index([providerId])
  @@map("llm_provider_models")
}

/// TB-021 — maps an agent×role → a specific model.
/// RLS via workspace_id (Admin + Lead per ERD §3 L940).
model AgentModelAssignment {
  id                      String    @id @default(uuid()) @db.Uuid
  workspaceId             String    @map("workspace_id") @db.Uuid
  agentKind               AgentKind @map("agent_kind")
  role                    AgentRole
  modelPk                 String    @map("model_pk") @db.Uuid
  activationThresholdJson Json?     @map("activation_threshold_json") @db.JsonB
  createdBy               String    @map("created_by") @db.Uuid
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  model     LlmProviderModel @relation(fields: [modelPk], references: [id], onDelete: Restrict)
  creator   User             @relation(fields: [createdBy], references: [id])

  @@unique([workspaceId, agentKind, role])
  @@index([workspaceId])
  @@map("agent_model_assignments")
}

// =============================================================================
// AUXILIARY TABLES (not in ERD §5 — designed from policy)
// =============================================================================

/// auxiliary — every A1/A2/A4 invocation. ERD describes intent ("status,
/// latency, eval result, runId") but no column list. First-pass minimum;
/// refine in M3 when agent specs solidify.
model AgentRun {
  id          String         @id @default(uuid()) @db.Uuid
  workspaceId String         @map("workspace_id") @db.Uuid
  agentKind   AgentKind      @map("agent_kind")
  status      AgentRunStatus @default(queued)
  startedAt   DateTime?      @map("started_at") @db.Timestamptz(6)
  completedAt DateTime?      @map("completed_at") @db.Timestamptz(6)
  durationMs  Int?           @map("duration_ms")
  evalResult  Json?          @map("eval_result") @db.JsonB
  errorClass  String?        @map("error_class")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rcaReports RcaReport[]

  @@index([workspaceId])
  @@index([agentKind, status])
  @@map("agent_runs")
}

// =============================================================================
// BETTERAUTH TABLES (added MS0-T021)
// =============================================================================
// BetterAuth's Prisma adapter manages these. We prefix the Postgres tables
// with `auth_` via @@map so they don't collide with our application `users`
// (TB-002). The link from BetterAuth identity → our application user is by
// `email` — the seed gives every TB-002 user a unique email, and BetterAuth's
// AuthUser.email is unique, so we resolve at the /auth/session boundary.
//
// Column shape per BetterAuth core schema (better-auth v1.x). The prismaAdapter
// expects these exact field names; do NOT rename without verifying BetterAuth's
// model-mapping config in apps/api/src/auth/auth.config.ts.
// =============================================================================

/// BetterAuth-managed identity. Linked to TB-002 `users` by email match
/// at the /auth/session boundary. Magic-link-only auth in PM1 — no password.
model AuthUser {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions AuthSession[]
  accounts AuthAccount[]

  @@map("auth_user")
}

/// BetterAuth session — issued after successful magic-link verification.
/// Token is opaque random; cookie name `better-auth.session_token`.
model AuthSession {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("auth_session")
}

/// BetterAuth account — links AuthUser to a credential provider. For PM1
/// magic-link-only this is mostly empty (no oauth providers yet) but
/// BetterAuth's adapter requires the table to exist.
model AuthAccount {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("auth_account")
}

/// BetterAuth verification — short-lived tokens for magic-link, email
/// verification, password reset (latter two unused in PM1 magic-link-only).
model AuthVerification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("auth_verification")
}

/// auxiliary — HMAC-SHA256 chained immutable rows (visible in F28).
/// NOT RLS-scoped; admin-only visibility enforced at app layer.
/// Append-only via REVOKE UPDATE,DELETE in raw SQL migration.
/// Genesis row: prev_hash = '0' * 64.
/// this_hash = HMAC_SHA256(BETTERAUTH_SECRET, prev_hash || row_payload_json).
model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  actorId     String?  @map("actor_id") @db.Uuid // nullable for system actions
  entityType  String   @map("entity_type") // "test_case", "defect", ...
  entityId    String?  @map("entity_id") @db.Uuid
  action      String // "created", "updated", "deleted", "redacted", ...
  payload     Json     @db.JsonB
  prevHash    String   @map("prev_hash") @db.Char(64)
  thisHash    String   @map("this_hash") @db.Char(64)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  actor         User?           @relation(fields: [actorId], references: [id], onDelete: SetNull)
  /// M4 (Day-18 #144) — back-relations from rows that pin themselves to an
  /// audit chain entry via audit_log_id FK. SetNull keeps the audit row
  /// immutable on cascade.
  evidence      Evidence[]
  defectHistory DefectHistory[]
  jiraSyncLogs  JiraSyncLog[]

  @@unique([workspaceId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_log")
}

// ────────────────────────────────────────────────────────────────────────────
// M4 (Day-18 #144) — Runs / Defects / Jira tables.
// Schema delta: apps/api/prisma/raw/migrations/0004_m4_runs_defects_jira.sql
// Spec: PM1_ERD v2.1 §3.6 / §3.7 / §3.9 / §3.10 / §7
// ────────────────────────────────────────────────────────────────────────────

/// M4 — screenshots / HARs / logs / videos attached to a test_run_result OR
/// a defect (XOR via DB CHECK constraint). r2_path is the canonical R2 key;
/// signed_url_expires_at is the lifetime of the currently-issued presigned
/// URL (re-issue if expired).
model Evidence {
  id                 String    @id @default(uuid()) @db.Uuid
  testRunResultId    String?   @map("test_run_result_id") @db.Uuid
  defectId           String?   @map("defect_id") @db.Uuid
  r2Path             String    @map("r2_path")
  signedUrlExpiresAt DateTime? @map("signed_url_expires_at") @db.Timestamptz(6)
  contentType        String?   @map("content_type")
  sizeBytes          BigInt?   @map("size_bytes")
  filename           String?
  createdBy          String?   @map("created_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  auditLogId         String?   @map("audit_log_id") @db.Uuid

  testRunResult TestRunResult? @relation(fields: [testRunResultId], references: [id], onDelete: Cascade)
  defect        Defect?        @relation(fields: [defectId], references: [id], onDelete: Cascade)
  creator       User?          @relation("EvidenceCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  auditLog      AuditLog?      @relation(fields: [auditLogId], references: [id], onDelete: SetNull)

  @@index([testRunResultId])
  @@index([defectId])
  @@index([createdBy])
  @@map("evidence")
}

/// M4 — defect state-transition audit trail. One row per status change.
/// from_status=NULL on the initial Create row. transitioned_at + audit_log_id
/// make this a tamper-evident chain via the audit_log HMAC reference.
model DefectHistory {
  id             String        @id @default(uuid()) @db.Uuid
  defectId       String        @map("defect_id") @db.Uuid
  fromStatus     DefectStatus? @map("from_status")
  toStatus       DefectStatus  @map("to_status")
  actorId        String?       @map("actor_id") @db.Uuid
  comment        String?
  transitionedAt DateTime      @default(now()) @map("transitioned_at") @db.Timestamptz(6)
  auditLogId     String?       @map("audit_log_id") @db.Uuid

  defect   Defect    @relation(fields: [defectId], references: [id], onDelete: Cascade)
  actor    User?     @relation("DefectHistoryActor", fields: [actorId], references: [id], onDelete: SetNull)
  auditLog AuditLog? @relation(fields: [auditLogId], references: [id], onDelete: SetNull)

  @@index([defectId, transitionedAt])
  @@index([actorId])
  @@map("defect_history")
}

/// M4 — inbound Jira webhook event log. UNIQUE on event_id for idempotent
/// dedupe (Jira retries on 5xx). signature_valid=false rows kept for
/// forensics. Process via processed=false partial index.
///
/// CRITICAL — Day-20 implementation note: Atlassian Jira webhooks compute
/// HMAC-SHA256 on RAW body bytes. Use a dedicated raw-body middleware on
/// /api/jira/webhook ONLY (rest of API keeps JSON parsing).
model JiraWebhookEvent {
  id              String    @id @default(uuid()) @db.Uuid
  eventId         String    @unique @map("event_id")
  jiraIssueKey    String?   @map("jira_issue_key")
  eventType       String    @map("event_type")
  payload         Json      @db.JsonB
  signatureValid  Boolean   @map("signature_valid")
  processed       Boolean   @default(false)
  processingError String?   @map("processing_error")
  receivedAt      DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt     DateTime? @map("processed_at") @db.Timestamptz(6)
  /// Day-22 P1 (ADR-020 §7 ratified) — incremented by the pg-listen
  /// subscriber's retry-with-backoff loop on transient failures. Reaching
  /// MAX_RETRIES (Day-23 wire-up) pushes the row to a DLQ via
  /// processed=true + processingError set.
  retryCount      Int       @default(0) @map("retry_count")

  @@index([receivedAt])
  @@index([jiraIssueKey])
  /// Day-22 — fallback "find unprocessed" scan if the LISTEN/NOTIFY
  /// subscriber misses an event (process crash, etc).
  @@index([processed, receivedAt])
  @@map("jira_webhook_events")
}

/// M4 — every Jira API call (outbound) or webhook processing (inbound).
/// payload_hash for dedupe + diff detection. retried + retryOf form a
/// retry chain. F28 Audit surfaces failed entries.
model JiraSyncLog {
  id               String   @id @default(uuid()) @db.Uuid
  jiraConnectionId String?  @map("jira_connection_id") @db.Uuid
  /// 'outbound' | 'inbound' (DB CHECK enforces).
  direction        String
  /// 'create_issue' | 'update_status' | 'fetch_issue' | 'process_webhook' | ...
  action           String
  defectId         String?  @map("defect_id") @db.Uuid
  jiraIssueKey     String?  @map("jira_issue_key")
  payloadHash      String   @map("payload_hash") @db.Char(64)
  httpStatus       Int?     @map("http_status")
  success          Boolean
  errorMessage     String?  @map("error_message")
  retried          Boolean  @default(false)
  retryOf          String?  @map("retry_of") @db.Uuid
  occurredAt       DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)
  auditLogId       String?  @map("audit_log_id") @db.Uuid

  jiraConnection JiraConnection? @relation(fields: [jiraConnectionId], references: [id], onDelete: SetNull)
  defect         Defect?         @relation(fields: [defectId], references: [id], onDelete: SetNull)
  retryParent    JiraSyncLog?    @relation("JiraSyncLogRetryChain", fields: [retryOf], references: [id], onDelete: SetNull)
  retries        JiraSyncLog[]   @relation("JiraSyncLogRetryChain")
  auditLog       AuditLog?       @relation(fields: [auditLogId], references: [id], onDelete: SetNull)

  @@index([jiraConnectionId])
  @@index([defectId])
  @@index([occurredAt])
  @@map("jira_sync_logs")
}
